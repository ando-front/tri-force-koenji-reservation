# フロントエンド環境変数
# このファイルをコピーして .env.local を作成してください

# Firebase プロジェクト設定（Firebase Console > プロジェクトの設定 > ウェブアプリ から取得）
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Cloud Functions のベースURL
# 本番: https://asia-northeast1-<project-id>.cloudfunctions.net/api
# ローカルエミュレーター: http://127.0.0.1:5001/<project-id>/asia-northeast1/api
VITE_FUNCTIONS_BASE_URL=http://127.0.0.1:5001/tri-force-koenji-reservation/asia-northeast1/api

# 開発モード（true の場合 Firebase エミュレーターを使用）
VITE_USE_EMULATORS=true
