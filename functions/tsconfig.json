{
  "compilerOptions": {
    "module":           "commonjs",
    "noImplicitReturns": true,
    "noUnusedLocals":   true,
    "outDir":           "lib",
    "sourceMap":        true,
    "strict":           true,
    "target":           "es2020",
    "esModuleInterop":  true,
    "skipLibCheck":     true,
    "baseUrl":          ".",
    "paths": {
      "@shared/*": ["../shared/*"],
      "zod": ["./node_modules/zod"]
    }
  },
  "compileOnSave": true,
  "include": ["src"],
  "exclude": ["node_modules"]
}
